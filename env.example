# Скопируйте этот файл в .env для локальной разработки
# На Railway эти переменные добавляются через Variables → New Variable

# Токен бота от @BotFather
BOT_TOKEN=your_bot_token_here

# Ваш личный Telegram ID (узнать у @userinfobot)
ADMIN_ID=123456789

# ID группы (отрицательное число, узнать через @getidsbot)
ALLOWED_GROUP_ID=-100987654321

# Дополнительные пользователи через запятую (необязательно)
ALLOWED_USER_IDS=111111111,222222222

# Путь к базе данных (на Railway используйте /data/finance.db с постоянным томом)
DB_PATH=/data/finance.db
